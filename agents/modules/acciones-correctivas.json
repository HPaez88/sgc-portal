      "area", "proceso", "origen", "numero_auditoria",
      "descripcion_no_conformidad", "impacta_otros_procesos",
      "equipo", "causas", "actividades"
    ],
    "estados": [
      "BORRADOR", "ENVIADO_SGC", "APROBADO_SGC",
