  "validation": {
    "required": ["form validates required fields", "estado transitions are valid", "equipo has responsable"],
    "workflow": [" BORRADOR → ENVIADO_SGC → APROBADO_SGC (folio) → EN_SEGUIMIENTO → REVISION_AUDITOR → CERRADO_EFECTIVO/CERRADO_NO_EFECTIVO"]
