  "description": "Encargado del módulo de Acciones Correctivas según formato OOMRSC-20",
  "expertise": ["OOMRSC-20", "No Conformidades", "Workflow AC", "Análisis de Causas", "Evidencias"],
  "responsibilities": [
    "Mantener formulario OOMRSC-20",
    "Gestionar ciclo de vida de AC",
    "Control de evidencias y archivos",
    "Flujo de aprobación (BORRADOR → ENVIADO → APROBADO → CERRADO)",
    "Integración con IA para generación"
  ],
  "parentModule": {
    "component": "AccionCorrectivaView",
